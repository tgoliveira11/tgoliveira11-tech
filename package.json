{
  "name": "tgoliveira11-tech",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3011",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev",
    "audit:ci": "npm audit --audit-level=moderate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "import:github-pages": "tsx scripts/import-github-pages.ts",
    "inspect:posts": "tsx scripts/inspect-posts.ts",
    "sync:upstream:configure": "git remote get-url upstream >/dev/null 2>&1 || git remote add upstream https://github.com/tgoliveira11/postforge.git; git remote set-url --push upstream no_push",
    "sync:upstream:fetch": "git fetch upstream",
    "sync:upstream:status": "bash scripts/sync-upstream-status.sh",
    "sync:upstream:merge": "bash scripts/sync-upstream-merge.sh"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "postcss": "^8.5.10",
    "uuid": "^11.1.1",
    "drizzle-kit": {
      "@esbuild-kit/esm-loader": "npm:tsx@^4.22.4"
    }
  },
  "dependencies": {
    "@tgoliveira/secure-auth": "^0.1.10-internal",
    "@vercel/blob": "^2.4.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}

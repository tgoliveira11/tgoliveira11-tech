# =============================================================================
# PostForge — environment template
# Copy to .env.local and fill in values. Never commit .env.local.
# Docs: docs/ENVIRONMENT_VARIABLES.md
# =============================================================================

# --- App ---
APP_BASE_URL=http://localhost:3000
APP_NAME="PostForge"
APP_SLUG=postforge
NODE_ENV=development

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgres://postforge:postforge@localhost:5432/postforge
# Max connections per Node process (default: 2 dev, 5 production)
DATABASE_POOL_MAX=2

# --- Auth / NextAuth (AUTH_SECRET in some docs = NEXTAUTH_SECRET here) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-secret
AUTH_AFTER_LOGIN_PATH=/admin
AUTH_AFTER_LOGOUT_PATH=/login
# Redirect signed-in users away from /login, /register, /forgot-password (default: true)
AUTH_REDIRECT_AUTHENTICATED_FROM_GUEST_PAGES=true
# Target when redirecting authenticated users from guest auth pages (default: AUTH_AFTER_LOGIN_PATH)
AUTH_AUTHENTICATED_REDIRECT_PATH=/admin

# --- OAuth — Google (optional) ---
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# --- OAuth — Apple (optional) ---
AUTH_APPLE_CLIENT_ID=
AUTH_APPLE_CLIENT_SECRET=

# --- OAuth — Microsoft (optional) ---
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_TENANT_ID=common

# --- Email ---
# Local development default: logs emails to the server console.
EMAIL_PROVIDER=console
EMAIL_FROM="PostForge <noreply@localhost>"

# Production option (each blog owner configures their own Resend account/domain):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=replace-with-your-resend-api-key
# EMAIL_FROM="Your Blog <noreply@mail.your-domain.com>"
# EMAIL_REPLY_TO="you@your-domain.com"
RESEND_API_KEY=
EMAIL_REPLY_TO=

# --- WebAuthn / Passkeys ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="PostForge"
WEBAUTHN_ORIGIN=http://localhost:3000

# --- Two-factor (generate a 32-byte base64 key for production) ---
TWO_FACTOR_SECRET_ENCRYPTION_KEY=change-me-to-32-byte-base64-key

# --- Sessions ---
AUTH_SESSION_MAX_AGE_SECONDS=2592000
AUTH_SESSION_LAST_USED_UPDATE_SECONDS=300
AUTH_SINGLE_ACTIVE_SESSION=false
AUTH_SESSION_REVOCATION_POLL_SECONDS=10

# --- Password policy ---
AUTH_PASSWORD_POLICY_ENFORCEMENT=warn
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_PASSWORD_REQUIRE_UPPERCASE=false
AUTH_PASSWORD_REQUIRE_LOWERCASE=false
AUTH_PASSWORD_REQUIRE_NUMBER=false
AUTH_PASSWORD_REQUIRE_SYMBOL=false
AUTH_PASSWORD_BLOCK_COMMON_PASSWORDS=true
AUTH_PASSWORD_MIN_SCORE=2
AUTH_PASSWORD_STRENGTH_POSITION=above

# --- Account / email verification ---
EMAIL_VERIFICATION_SEND_ON_REGISTER=true
EMAIL_VERIFICATION_REQUIRE_BEFORE_SIGN_IN=false
# Block sensitive account APIs until email is verified (secure-auth ≥ 0.1.21)
EMAIL_VERIFICATION_REQUIRE_FOR_ACCOUNT_APIS=true

# --- API security (secure-auth ≥ 0.1.21) ---
# Reject cross-origin mutating account/auth API calls (uses APP_BASE_URL + WEBAUTHN_ORIGIN)
AUTH_SAME_ORIGIN_PROTECTION_ENABLED=true
# Optional comma-separated extra allowed origins (e.g. preview deployments)
AUTH_ALLOWED_ORIGINS=

# --- Rate limiting ---
AUTH_RATE_LIMIT_STORE=memory

# --- Cookies (set AUTH_COOKIE_SECURE=true in HTTPS production) ---
AUTH_COOKIE_SECURE=

# --- Debug ---
AUTH_TRACE=false
# Both must be true to expose GET /api/auth/login/trace — never enable in production
AUTH_DEBUG_EXPOSE_TRACE_ROUTE=false

# --- PostForge blog / admin ---
# Must match the email you register with at /register
ADMIN_EMAIL=you@example.com

# Public /blog pagination (default: 5, max: 50).
PUBLIC_POSTS_PAGE_SIZE=5

# Home recent posts grid (default: 12, max: 48). Does not affect /blog pagination.
HOME_RECENT_POSTS_LIMIT=12

# Home "Explore by category" section (default: 6, max: 24).
HOME_POPULAR_CATEGORIES_LIMIT=6

# --- Uploads / storage (see docs/STORAGE_STRATEGY.md) ---
# local = filesystem (development / VPS)
# vercel-blob = Vercel Blob (production on Vercel)
UPLOAD_PROVIDER=local
UPLOAD_LOCAL_DIR=./storage/uploads
UPLOAD_PUBLIC_BASE_URL=/api/assets
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
# Alias also supported: UPLOAD_MAX_FILE_SIZE=5242880

# Required only when UPLOAD_PROVIDER=vercel-blob (Vercel sets this when you connect a Blob store)
BLOB_READ_WRITE_TOKEN=

# --- Public appearance ---
# Leave empty to let visitors choose the theme.
# Set to "light" or "dark" to force the public site theme and hide the public theme toggle.
PUBLIC_SITE_THEME=

# --- Cron (required in production if using scheduled publish endpoints) ---
CRON_SECRET=change-me-to-a-long-random-secret

# --- Analytics (reserved — toggled via blog_settings DB today) ---
ANALYTICS_ENABLED=
# Store raw visitor IP in analytics_events when true. Default false stores only a hashed IP.
ANALYTICS_STORE_RAW_IP=false

# --- Timezone (reserved — not wired in code yet) ---
DEFAULT_TIMEZONE=America/Sao_Paulo
